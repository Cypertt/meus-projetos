CREATE TABLE pedidos(
	id SERIAL PRIMARY KEY,
	nome VARCHAR(50),
	valor NUMERIC(10,2),
	hamb INT,
	acomp INT,


	FOREIGN KEY (hamb) REFERENCES hamburguers(id),
	FOREIGN KEY (acomp) REFERENCES acompanhamentos(id)
);

