SELECT
	pedidos.nome AS cliente,
	hamburguers.nome AS lanche,
	acompanhamentos.nome AS acompanhamento
	FROM pedidos
	INNER JOIN hamburguers ON pedidos.hamb = hamburguers.id
	INNER JOIN acompanhamentos ON pedidos.acomp = acompanhamentos.id;
